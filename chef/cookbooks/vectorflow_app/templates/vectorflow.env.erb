# =================================
# VectorFlow Environment Variables
# =================================
# Managed by Chef - DO NOT EDIT MANUALLY
# This file contains sensitive configuration
#
# Generated: <%= Time.now.utc.iso8601 %>
# =================================

# Environment
ENVIRONMENT=production
LOG_LEVEL=<%= @logging['level'] %>

# Model Configuration
MODEL_NAME=<%= @model['name'] %>
MODEL_CACHE_DIR=<%= @model['cache_dir'] %>
BATCH_SIZE=<%= @model['batch_size'] %>
MAX_SEQUENCE_LENGTH=<%= @model['max_sequence_length'] %>

# Pinecone Configuration
PINECONE_ENVIRONMENT=<%= @pinecone['environment'] %>
PINECONE_INDEX_NAME=<%= @pinecone['index_name'] %>
# PINECONE_API_KEY should be set via secrets management

# Service URLs (internal)
GATEWAY_SERVICE_URL=http://vectorflow-gateway:8080
WORKER_SERVICE_URL=http://vectorflow-worker:8081
INFERENCE_SERVICE_URL=http://vectorflow-inference:8082
