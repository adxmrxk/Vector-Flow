# Limits for vectorflow user
<% @limits.each do |limit_type, values| -%>
<%= @user %>    soft    <%= limit_type %>    <%= values['soft'] %>
<%= @user %>    hard    <%= limit_type %>    <%= values['hard'] %>
<% end -%>

# Limits for root (required for systemd services)
<% @limits.each do |limit_type, values| -%>
root    soft    <%= limit_type %>    <%= values['soft'] %>
root    hard    <%= limit_type %>    <%= values['hard'] %>
<% end -%>
