#!/bin/bash
# =================================
# VectorFlow Minikube Stop Script
# =================================
# Managed by Chef - DO NOT EDIT MANUALLY

set -e

echo "Stopping VectorFlow Minikube cluster..."

if minikube status > /dev/null 2>&1; then
    minikube stop
    echo "Minikube cluster stopped successfully"
else
    echo "Minikube is not running"
fi
