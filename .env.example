# =========================
# VectorFlow Environment Variables
# =========================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ----- Environment -----
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# ----- Service Ports -----
GO_GATEWAY_PORT=8080
RUST_WORKER_PORT=8081
PYTHON_INFERENCE_PORT=8082
FRONTEND_PORT=3000

# ----- Go Gateway -----
GATEWAY_HOST=0.0.0.0
GATEWAY_READ_TIMEOUT=30s
GATEWAY_WRITE_TIMEOUT=30s
GATEWAY_CORS_ORIGINS=http://localhost:3000

# ----- Rust Worker -----
WORKER_HOST=0.0.0.0
WORKER_MAX_CONNECTIONS=100
WORKER_THREAD_POOL_SIZE=4

# ----- Python Inference -----
INFERENCE_HOST=0.0.0.0
MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
MODEL_CACHE_DIR=./models
BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=512

# ----- Pinecone (Vector DB) -----
PINECONE_API_KEY=your-api-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=vectorflow-index

# ----- Service Discovery -----
WORKER_SERVICE_URL=http://localhost:8081
INFERENCE_SERVICE_URL=http://localhost:8082
GATEWAY_SERVICE_URL=http://localhost:8080

# ----- Authentication (Optional) -----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
API_KEY_HEADER=X-API-Key

# ----- Monitoring -----
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ----- Docker Registry -----
DOCKER_REGISTRY=localhost:5000
IMAGE_TAG=latest

# ----- Kubernetes -----
K8S_NAMESPACE=vectorflow
K8S_CONTEXT=minikube

# ----- AWS (Optional - Free Tier) -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ----- Jenkins -----
JENKINS_URL=http://localhost:8090
JENKINS_USER=admin
JENKINS_TOKEN=
