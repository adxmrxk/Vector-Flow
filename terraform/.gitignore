# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variables (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Terraform cache
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Plan files
*.tfplan
plan.out

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
