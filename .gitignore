# =========================
# VectorFlow .gitignore
# =========================

# ----- Environment & Secrets -----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials/

# ----- OS Generated -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- IDE & Editors -----
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
*.iml

# ----- Go -----
go/bin/
go/pkg/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
go.work

# ----- Rust -----
rust/target/
**/*.rs.bk
Cargo.lock
!rust/Cargo.lock

# ----- Python -----
python/__pycache__/
python/**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/
venv/
.venv/
ENV/

# ----- Node.js / Next.js -----
node_modules/
.next/
out/
.nuxt/
.cache/
*.tsbuildinfo
.npm
.yarn/
.pnp.*

# ----- Docker -----
*.log
docker-compose.override.yml

# ----- Kubernetes -----
*.kubeconfig
kubeconfig
k8s/secrets/*.yaml
!k8s/secrets/.gitkeep

# ----- Terraform (if used) -----
.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example

# ----- Ansible -----
ansible/*.retry
ansible/inventory/hosts
!ansible/inventory/hosts.example

# ----- Jenkins -----
jenkins/secrets/
jenkins/*.log

# ----- Chef -----
infrastructure/chef/.chef/
infrastructure/chef/cookbooks/*/Berksfile.lock
infrastructure/chef/nodes/

# ----- Build Artifacts -----
bin/
tmp/
temp/
*.bak
*.backup

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Coverage -----
coverage/
*.lcov

# ----- ML/AI Models (large files) -----
models/
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.joblib
!models/.gitkeep
